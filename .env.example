# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Supabase → Project Settings → Database)
# Use the "URI" under Connection string. If the app cannot reach :5432 (firewall, etc.), try the
# Connection pooler string (Session or Transaction mode) from the same page instead.
# If you see "Can't reach database server", resume a paused project in the Supabase dashboard, fix
# the password in this URL, or switch network / VPN.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=

# YouTube / TikTok / Instagram OAuth (optional: leave empty for local build; set all three for each platform to enable “Connect”)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/auth/callback/youtube

TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/api/auth/callback/tiktok

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/auth/callback/instagram

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional; reserved for future use — can be left empty for local
NEXTAUTH_SECRET=
