# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Supabase → Project Settings → Database)
#
# Local dev: "Direct connection" (port 5432) is usually fine.
#
# Netlify / serverless: do NOT use the same direct :5432 URL. In Supabase open the pooler string
# (Transaction mode, port 6543) and append these query params for Prisma:
#   ?pgbouncer=true&connection_limit=1&sslmode=require
# (Supabase’s UI may show some of this already; merge so they are all present once.)
# Paste that full value as DATABASE_URL in Netlify → Site configuration → Environment variables.
# See: https://www.prisma.io/docs/orm/overview/databases/postgresql#using-a-connection-pooler
#
# If the app says it cannot reach the database: resume a paused project, check the password in the
# URL, and on Netlify ensure DATABASE_URL is the pooler URL, not a placeholder.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=

# YouTube / TikTok / Instagram OAuth (optional: leave empty for local build; set all three for each platform to enable “Connect”)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/auth/callback/youtube

TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/api/auth/callback/tiktok

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/auth/callback/instagram

# App
# Public site URL (no trailing slash). Production/Netlify: e.g. https://your-app.netlify.app
# This is used for magic link redirect targets. In Supabase → Authentication → URL configuration:
# set Site URL to the same origin, and add https://.../auth/confirm (or http://localhost:3000/auth/confirm)
# under Redirect URLs. Mismatch causes “Error sending confirmation email” or invalid redirect.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional; reserved for future use — can be left empty for local
NEXTAUTH_SECRET=
